# Discord Bot Configuration
# Copy this to .env and fill in your values

# Get these from https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here

# PostgreSQL database URL
# Format: postgres://username:password@localhost:5432/database_name
DATABASE_URL=postgres://user:password@localhost:5432/loopconomy

# Optional: User ID to receive taxes from /pay command (over 100 coins)
# TAX_COLLECTOR_ID=your_user_id_here
